---
import '../styles/global.css';
import OnboardingModal from '../components/OnboardingModal';
import ExamCountdown from '../components/ExamCountdown';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Master Snowflake with comprehensive training for the SnowPro Core Certification (COF-C02)' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Social sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.svg" />

    <!-- PWA / App -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#29b5e8" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Pagefind search UI (available after npm run build) -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

    <!-- Apply saved theme before render to prevent flash -->
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('sf-theme');
          if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        } catch(e) {}
      })();
    </script>

    <title>{title}</title>
  </head>
  <body>
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- Skip to main content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[300] focus:px-4 focus:py-2 focus:rounded-lg focus:font-semibold focus:text-white"
      style="background: var(--color-snowflake-blue);"
    >
      Skip to main content
    </a>

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm" role="banner">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity no-underline" aria-label="Snowflake Training — Home">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, var(--color-snowflake-blue), var(--color-snowflake-sky));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-lg text-slate-900">Snowflake Training</div>
              <div class="text-xs" style="color: var(--color-snowflake-blue);">by Hamzah Javaid</div>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-1">
            <a href="/" data-nav-link class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Home</a>
            <a href="/#section-features" data-nav-link data-home-section="section-features" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Features</a>
            <a href="/#section-testimonials" data-nav-link data-home-section="section-testimonials" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Testimonials</a>
            <a href="/#get-the-app" data-nav-link data-home-section="get-the-app" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Get App</a>
            <a href="/modules" data-nav-link class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Modules</a>
            <a href="/flashcards" data-nav-link class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Flashcards</a>
            <a href="/cheatsheets" data-nav-link class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Cheat Sheets</a>
            <a href="/exam-sim" data-nav-link class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Mock Exam</a>
            <a href="/practice" data-nav-link class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">SQL Practice</a>

            <!-- Dark mode toggle -->
            <button
              id="theme-toggle"
              class="ml-1 p-2 rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition-all"
              aria-label="Toggle dark mode"
              title="Toggle dark mode"
            >
              <!-- Sun icon (shown in dark mode) -->
              <svg id="theme-sun" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07l-.71.71M6.34 17.66l-.71.71m12.73 0l-.71-.71M6.34 6.34l-.71-.71M12 5a7 7 0 100 14A7 7 0 0012 5z" />
              </svg>
              <!-- Moon icon (shown in light mode) -->
              <svg id="theme-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>

            <!-- Search -->
            <button
              id="search-button"
              class="ml-1 flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 text-slate-500 hover:border-primary hover:text-primary transition-all text-sm"
              aria-label="Search (Ctrl+K)"
              aria-haspopup="dialog"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span class="hidden lg:inline">Search</span>
              <kbd class="hidden lg:inline text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-400 font-sans">⌘K</kbd>
            </button>
          </div>

          <!-- Mobile: theme + search + hamburger -->
          <div class="flex md:hidden items-center gap-1">
            <button id="mobile-theme-toggle" class="p-2 rounded-lg text-slate-600 hover:bg-slate-100" aria-label="Toggle dark mode">
              <svg id="mobile-theme-sun" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07l-.71.71M6.34 17.66l-.71.71m12.73 0l-.71-.71M6.34 6.34l-.71-.71M12 5a7 7 0 100 14A7 7 0 0012 5z" />
              </svg>
              <svg id="mobile-theme-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>
            <button id="mobile-search-btn" class="p-2 rounded-lg text-slate-600 hover:bg-slate-100" aria-label="Search">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
            <button
              id="mobile-menu-btn"
              class="p-2 rounded-lg text-slate-600 hover:bg-slate-100"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="mobile-menu"
            >
              <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </nav>

      <!-- Mobile menu dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white shadow-lg" role="navigation" aria-label="Mobile navigation">
        <nav class="max-w-7xl mx-auto px-4 py-3 space-y-1">
          <a href="/" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Home</a>
          <a href="/#section-features" data-nav-link data-home-section="section-features" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Features</a>
          <a href="/#section-testimonials" data-nav-link data-home-section="section-testimonials" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Testimonials</a>
          <a href="/#get-the-app" data-nav-link data-home-section="get-the-app" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Get App</a>
          <a href="/about" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">About</a>
          <a href="/modules" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Modules</a>
          <a href="/flashcards" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Flashcards</a>
          <a href="/cheatsheets" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Cheat Sheets</a>
          <a href="/exam-sim" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Mock Exam</a>
          <a href="/practice" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">SQL Practice</a>
          <a href="/certificate" data-nav-link class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">🏆 Certificate</a>
        </nav>
      </div>
    </header>

    <!-- Exam countdown banner (shows if user set exam date during onboarding) -->
    <ExamCountdown client:load />

    <!-- Search Modal Overlay -->
    <div
      id="search-modal"
      class="hidden fixed inset-0 z-[200] flex items-start justify-center pt-16 px-4"
      role="dialog"
      aria-modal="true"
      aria-label="Search"
    >
      <div id="search-backdrop" class="absolute inset-0" style="background: rgba(15,23,42,0.6); backdrop-filter: blur(4px);"></div>
      <div class="relative w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden" style="max-height: 80vh; display: flex; flex-direction: column;">
        <div class="p-4 overflow-y-auto flex-1">
          <div id="pagefind-search" role="search"></div>
          <div id="search-fallback" class="hidden py-10 text-center">
            <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p class="text-sm text-slate-500">Search is available in the production build.</p>
            <p class="text-xs text-slate-400 mt-1">Run <code class="bg-slate-100 px-1 py-0.5 rounded font-mono">npm run build</code> then <code class="bg-slate-100 px-1 py-0.5 rounded font-mono">npm run preview</code></p>
          </div>
        </div>
        <div class="px-4 py-3 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
          <span class="text-xs text-slate-400">
            Press <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-xs">Esc</kbd> to close
            &nbsp;·&nbsp;
            <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-xs">⌘K</kbd> to open
          </span>
          <button id="close-search-btn" class="text-sm text-slate-500 hover:text-slate-800 font-medium">Close</button>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-300 mt-24" role="contentinfo">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-center text-center">
          <div class="flex flex-col items-center">
            <div class="flex items-center justify-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, var(--color-snowflake-blue), var(--color-snowflake-sky));">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
              </div>
              <div>
                <div class="font-bold text-white">Snowflake Training</div>
                <div class="text-xs" style="color: var(--color-snowflake-blue);">by Hamzah Javaid</div>
              </div>
            </div>
            <p class="text-sm text-slate-400">Hamzah Javaid 2026</p>
          </div>
        </div>
      </div>
    </footer>

    <!-- Service Worker -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>

    <!-- Dark mode toggle -->
    <script is:inline>
      (function() {
        function isDark() {
          return document.documentElement.getAttribute('data-theme') === 'dark';
        }

        function setTheme(dark) {
          if (dark) {
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('sf-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('sf-theme', 'light');
          }
          // Update all toggle icons
          ['theme-sun','mobile-theme-sun'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.classList.toggle('hidden', !dark);
          });
          ['theme-moon','mobile-theme-moon'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.classList.toggle('hidden', dark);
          });
        }

        // Set initial icon state
        setTheme(isDark());

        // Wire buttons
        ['theme-toggle','mobile-theme-toggle'].forEach(function(id) {
          var btn = document.getElementById(id);
          if (btn) btn.addEventListener('click', function() { setTheme(!isDark()); });
        });
      })();
    </script>

    <!-- Active navigation + magnetic CTA interactions -->
    <script is:inline>
      (function() {
        var links = Array.from(document.querySelectorAll('[data-nav-link]'));
        var isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var isCoarse = window.matchMedia('(pointer: coarse)').matches;

        function normalizePath(path) {
          return path.replace(/\/+$/, '') || '/';
        }

        function setActiveLink() {
          var currentPath = normalizePath(window.location.pathname);
          links.forEach(function(link) {
            link.classList.remove('nav-active');
            var href = link.getAttribute('href') || '';
            if (!href) return;
            var url = new URL(href, window.location.origin);
            var targetPath = normalizePath(url.pathname);
            var sectionId = link.getAttribute('data-home-section');

            if (sectionId && currentPath === '/') return;
            if (targetPath === currentPath && !sectionId) link.classList.add('nav-active');
          });
        }

        function setHomeSectionActive(sectionId) {
          if (normalizePath(window.location.pathname) !== '/') return;
          links.forEach(function(link) {
            var homeSection = link.getAttribute('data-home-section');
            var href = link.getAttribute('href');
            if (href === '/') link.classList.remove('nav-active');
            if (!homeSection) return;
            if (homeSection === sectionId) link.classList.add('nav-active');
            else link.classList.remove('nav-active');
          });
        }

        setActiveLink();

        if (normalizePath(window.location.pathname) === '/') {
          var sections = Array.from(document.querySelectorAll('[id][data-bg-theme]'));
          if (sections.length) {
            var io = new IntersectionObserver(function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting) setHomeSectionActive(entry.target.id);
              });
            }, { threshold: 0.4 });
            sections.forEach(function(section) { io.observe(section); });
          }
        }

        if (isReduced || isCoarse) return;
        var magneticTargets = Array.from(document.querySelectorAll('[data-magnetic], .btn-primary'));
        magneticTargets.forEach(function(el) {
          el.classList.add('magnetic-ready');
          el.addEventListener('pointermove', function(e) {
            var rect = el.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            var dx = (x / rect.width - 0.5) * 10;
            var dy = (y / rect.height - 0.5) * 8;
            el.style.transform = 'translate3d(' + dx.toFixed(2) + 'px,' + dy.toFixed(2) + 'px,0)';
          });
          el.addEventListener('pointerdown', function() {
            el.style.transform = 'translate3d(0,0,0) scale(0.98)';
          });
          el.addEventListener('pointerleave', function() {
            el.style.transform = 'translate3d(0,0,0)';
          });
          el.addEventListener('pointerup', function() {
            el.style.transform = 'translate3d(0,0,0)';
          });
        });
      })();
    </script>

    <!-- Mobile menu -->
    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var ham = document.getElementById('hamburger-icon');
        var cls = document.getElementById('close-icon');
        if (!btn || !menu) return;

        btn.addEventListener('click', function() {
          var isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden', isOpen);
          ham.classList.toggle('hidden', !isOpen);
          cls.classList.toggle('hidden', isOpen);
          btn.setAttribute('aria-expanded', String(!isOpen));
        });

        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
            menu.classList.add('hidden');
            ham.classList.remove('hidden');
            cls.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
            btn.focus();
          }
        });

        // Close when a nav link is tapped (important on mobile SPA-style navigation)
        menu.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            menu.classList.add('hidden');
            ham.classList.remove('hidden');
            cls.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();
    </script>

    <!-- Search modal + Pagefind -->
    <script is:inline>
      (function() {
        var modal = document.getElementById('search-modal');
        var backdrop = document.getElementById('search-backdrop');
        var closeBtn = document.getElementById('close-search-btn');
        var searchBtn = document.getElementById('search-button');
        var mobileSearchBtn = document.getElementById('mobile-search-btn');
        var mobileMenu = document.getElementById('mobile-menu');
        var pfEl = document.getElementById('pagefind-search');
        var fallback = document.getElementById('search-fallback');
        var initialized = false;

        function openSearch() {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          modal.setAttribute('aria-hidden', 'false');
          if (!initialized) {
            initialized = true;
            if (typeof window.PagefindUI !== 'undefined') {
              new window.PagefindUI({ element: '#pagefind-search', showSubResults: true, resetStyles: false });
            } else {
              pfEl.classList.add('hidden');
              fallback.classList.remove('hidden');
            }
          }
          setTimeout(function() {
            var inp = pfEl.querySelector('input');
            if (inp) inp.focus();
          }, 80);
        }

        function closeSearch() {
          modal.classList.add('hidden');
          document.body.style.overflow = '';
          modal.setAttribute('aria-hidden', 'true');
        }

        modal.setAttribute('aria-hidden', 'true');
        if (searchBtn) searchBtn.addEventListener('click', openSearch);
        if (mobileSearchBtn) mobileSearchBtn.addEventListener('click', function() {
          if (mobileMenu) mobileMenu.classList.add('hidden');
          openSearch();
        });
        if (backdrop) backdrop.addEventListener('click', closeSearch);
        if (closeBtn) closeBtn.addEventListener('click', closeSearch);

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closeSearch();
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
        });
      })();
    </script>

    <!-- Scroll ambience + progress -->
    <script is:inline>
      (function() {
        var root = document.documentElement;
        var progress = document.getElementById('scroll-progress');
        var sections = Array.from(document.querySelectorAll('[data-bg-theme]'));
        if (!sections.length) return;

        function parseRGB(value, fallback) {
          var raw = (value || fallback || '15,23,42').split(',');
          if (raw.length !== 3) return fallback || '15,23,42';
          var nums = raw.map(function(part) {
            var n = parseInt(part.trim(), 10);
            if (Number.isNaN(n)) return 0;
            return Math.min(255, Math.max(0, n));
          });
          return nums.join(', ');
        }

        function getTheme(section) {
          return {
            bg1: parseRGB(section.getAttribute('data-bg1'), '15,23,42'),
            bg2: parseRGB(section.getAttribute('data-bg2'), '30,58,95'),
            bg3: parseRGB(section.getAttribute('data-bg3'), '8,47,73'),
            accent: parseRGB(section.getAttribute('data-accent'), '41,181,232')
          };
        }

        function toArr(rgb) {
          return rgb.split(',').map(function(v) { return parseInt(v.trim(), 10) || 0; });
        }

        function mixRGB(a, b, t) {
          var out = [0, 0, 0];
          for (var i = 0; i < 3; i++) out[i] = Math.round(a[i] + (b[i] - a[i]) * t);
          return out.join(', ');
        }

        function sectionTop(section) {
          var rect = section.getBoundingClientRect();
          return rect.top + window.scrollY;
        }

        function getActiveBlend() {
          if (sections.length === 1) {
            return { from: getTheme(sections[0]), to: getTheme(sections[0]), t: 0 };
          }

          var y = window.scrollY + window.innerHeight * 0.45;
          var idx = 0;
          for (var i = 0; i < sections.length - 1; i++) {
            var start = sectionTop(sections[i]);
            var end = sectionTop(sections[i + 1]);
            if (y >= start && y <= end) {
              idx = i;
              break;
            }
            if (y > end) idx = i + 1;
          }

          var current = sections[Math.min(idx, sections.length - 1)];
          var next = sections[Math.min(idx + 1, sections.length - 1)];
          var currentTop = sectionTop(current);
          var nextTop = sectionTop(next);
          var span = Math.max(1, nextTop - currentTop);
          var t = Math.min(1, Math.max(0, (y - currentTop) / span));
          return { from: getTheme(current), to: getTheme(next), t: t };
        }

        var ticking = false;
        function update() {
          var blend = getActiveBlend();
          var from1 = toArr(blend.from.bg1);
          var from2 = toArr(blend.from.bg2);
          var from3 = toArr(blend.from.bg3);
          var fromA = toArr(blend.from.accent);
          var to1 = toArr(blend.to.bg1);
          var to2 = toArr(blend.to.bg2);
          var to3 = toArr(blend.to.bg3);
          var toA = toArr(blend.to.accent);

          root.style.setProperty('--ux-bg-1', mixRGB(from1, to1, blend.t));
          root.style.setProperty('--ux-bg-2', mixRGB(from2, to2, blend.t));
          root.style.setProperty('--ux-bg-3', mixRGB(from3, to3, blend.t));
          root.style.setProperty('--ux-accent', mixRGB(fromA, toA, blend.t));

          var scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
          var pct = scrollHeight > 0 ? (window.scrollY / scrollHeight) * 100 : 0;
          root.style.setProperty('--scroll-progress', pct.toFixed(2) + '%');
          if (progress) progress.style.opacity = window.scrollY > 12 ? '1' : '0.72';

          ticking = false;
        }

        function requestUpdate() {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(update);
        }

        window.addEventListener('scroll', requestUpdate, { passive: true });
        window.addEventListener('resize', requestUpdate);
        update();
      })();
    </script>

    <!-- Pagefind UI script — generated by build, silently absent in dev -->
    <script is:inline>
      (function() {
        var s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.onerror = function() {}; // silent in dev
        document.head.appendChild(s);
      })();
    </script>

    <!-- First-visit onboarding modal -->
    <OnboardingModal client:load />
  </body>
</html>
