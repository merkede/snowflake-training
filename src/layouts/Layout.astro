---
import '../styles/global.css';
import OnboardingModal from '../components/OnboardingModal';
import ExamCountdown from '../components/ExamCountdown';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Master Snowflake with comprehensive training for the SnowPro Core Certification (COF-C02)' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Social sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.svg" />

    <!-- PWA / App -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#29b5e8" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Pagefind search UI (available after npm run build) -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

    <!-- Apply saved theme before render to prevent flash -->
    <script is:inline>
      (function() {
        try {
          var t = localStorage.getItem('sf-theme');
          if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        } catch(e) {}
      })();
    </script>

    <title>{title}</title>
  </head>
  <body>
    <!-- Skip to main content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[300] focus:px-4 focus:py-2 focus:rounded-lg focus:font-semibold focus:text-white"
      style="background: var(--color-snowflake-blue);"
    >
      Skip to main content
    </a>

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm" role="banner">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity no-underline" aria-label="Snowflake Training — Home">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, var(--color-snowflake-blue), var(--color-snowflake-sky));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-lg text-slate-900">Snowflake Training</div>
              <div class="text-xs" style="color: var(--color-snowflake-blue);">by Hamzah Javaid</div>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-1">
            <a href="/" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Home</a>
            <a href="/modules" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Modules</a>
            <a href="/flashcards" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Flashcards</a>
            <a href="/cheatsheets" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Cheat Sheets</a>
            <a href="/exam-sim" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Mock Exam</a>
            <a href="/practice" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">SQL Practice</a>

            <!-- Dark mode toggle -->
            <button
              id="theme-toggle"
              class="ml-1 p-2 rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition-all"
              aria-label="Toggle dark mode"
              title="Toggle dark mode"
            >
              <!-- Sun icon (shown in dark mode) -->
              <svg id="theme-sun" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07l-.71.71M6.34 17.66l-.71.71m12.73 0l-.71-.71M6.34 6.34l-.71-.71M12 5a7 7 0 100 14A7 7 0 0012 5z" />
              </svg>
              <!-- Moon icon (shown in light mode) -->
              <svg id="theme-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>

            <!-- Search -->
            <button
              id="search-button"
              class="ml-1 flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 text-slate-500 hover:border-primary hover:text-primary transition-all text-sm"
              aria-label="Search (Ctrl+K)"
              aria-haspopup="dialog"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span class="hidden lg:inline">Search</span>
              <kbd class="hidden lg:inline text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-400 font-sans">⌘K</kbd>
            </button>
          </div>

          <!-- Mobile: theme + search + hamburger -->
          <div class="flex md:hidden items-center gap-1">
            <button id="mobile-theme-toggle" class="p-2 rounded-lg text-slate-600 hover:bg-slate-100" aria-label="Toggle dark mode">
              <svg id="mobile-theme-sun" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.07l-.71.71M6.34 17.66l-.71.71m12.73 0l-.71-.71M6.34 6.34l-.71-.71M12 5a7 7 0 100 14A7 7 0 0012 5z" />
              </svg>
              <svg id="mobile-theme-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            </button>
            <button id="mobile-search-btn" class="p-2 rounded-lg text-slate-600 hover:bg-slate-100" aria-label="Search">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
            <button
              id="mobile-menu-btn"
              class="p-2 rounded-lg text-slate-600 hover:bg-slate-100"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="mobile-menu"
            >
              <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </nav>

      <!-- Mobile menu dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white shadow-lg" role="navigation" aria-label="Mobile navigation">
        <nav class="max-w-7xl mx-auto px-4 py-3 space-y-1">
          <a href="/" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Home</a>
          <a href="/about" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">About</a>
          <a href="/modules" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Modules</a>
          <a href="/flashcards" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Flashcards</a>
          <a href="/cheatsheets" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Cheat Sheets</a>
          <a href="/exam-sim" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Mock Exam</a>
          <a href="/practice" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">SQL Practice</a>
          <a href="/certificate" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">🏆 Certificate</a>
        </nav>
      </div>
    </header>

    <!-- Exam countdown banner (shows if user set exam date during onboarding) -->
    <ExamCountdown client:load />

    <!-- Search Modal Overlay -->
    <div
      id="search-modal"
      class="hidden fixed inset-0 z-[200] flex items-start justify-center pt-16 px-4"
      role="dialog"
      aria-modal="true"
      aria-label="Search"
    >
      <div id="search-backdrop" class="absolute inset-0" style="background: rgba(15,23,42,0.6); backdrop-filter: blur(4px);"></div>
      <div class="relative w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden" style="max-height: 80vh; display: flex; flex-direction: column;">
        <div class="p-4 overflow-y-auto flex-1">
          <div id="pagefind-search" role="search"></div>
          <div id="search-fallback" class="hidden py-10 text-center">
            <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p class="text-sm text-slate-500">Search is available in the production build.</p>
            <p class="text-xs text-slate-400 mt-1">Run <code class="bg-slate-100 px-1 py-0.5 rounded font-mono">npm run build</code> then <code class="bg-slate-100 px-1 py-0.5 rounded font-mono">npm run preview</code></p>
          </div>
        </div>
        <div class="px-4 py-3 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
          <span class="text-xs text-slate-400">
            Press <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-xs">Esc</kbd> to close
            &nbsp;·&nbsp;
            <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-xs">⌘K</kbd> to open
          </span>
          <button id="close-search-btn" class="text-sm text-slate-500 hover:text-slate-800 font-medium">Close</button>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-300 mt-24" role="contentinfo">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div>
          <div>
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, var(--color-snowflake-blue), var(--color-snowflake-sky));">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
              </div>
              <div>
                <div class="font-bold text-white">Snowflake Training</div>
                <div class="text-xs" style="color: var(--color-snowflake-blue);">by Hamzah Javaid</div>
              </div>
            </div>
            <p class="text-sm text-slate-400">Hamzah Javaid 2026</p>
          </div>
        </div>
      </div>
    </footer>

    <!-- Service Worker -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>

    <!-- Dark mode toggle -->
    <script is:inline>
      (function() {
        function isDark() {
          return document.documentElement.getAttribute('data-theme') === 'dark';
        }

        function setTheme(dark) {
          if (dark) {
            document.documentElement.setAttribute('data-theme', 'dark');
            localStorage.setItem('sf-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('sf-theme', 'light');
          }
          // Update all toggle icons
          ['theme-sun','mobile-theme-sun'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.classList.toggle('hidden', !dark);
          });
          ['theme-moon','mobile-theme-moon'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.classList.toggle('hidden', dark);
          });
        }

        // Set initial icon state
        setTheme(isDark());

        // Wire buttons
        ['theme-toggle','mobile-theme-toggle'].forEach(function(id) {
          var btn = document.getElementById(id);
          if (btn) btn.addEventListener('click', function() { setTheme(!isDark()); });
        });
      })();
    </script>

    <!-- Mobile menu -->
    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var ham = document.getElementById('hamburger-icon');
        var cls = document.getElementById('close-icon');
        if (!btn || !menu) return;

        btn.addEventListener('click', function() {
          var isOpen = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden', isOpen);
          ham.classList.toggle('hidden', !isOpen);
          cls.classList.toggle('hidden', isOpen);
          btn.setAttribute('aria-expanded', String(!isOpen));
        });

        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
            menu.classList.add('hidden');
            ham.classList.remove('hidden');
            cls.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
            btn.focus();
          }
        });

        // Close when a nav link is tapped (important on mobile SPA-style navigation)
        menu.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            menu.classList.add('hidden');
            ham.classList.remove('hidden');
            cls.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();
    </script>

    <!-- Search modal + Pagefind -->
    <script is:inline>
      (function() {
        var modal = document.getElementById('search-modal');
        var backdrop = document.getElementById('search-backdrop');
        var closeBtn = document.getElementById('close-search-btn');
        var searchBtn = document.getElementById('search-button');
        var mobileSearchBtn = document.getElementById('mobile-search-btn');
        var mobileMenu = document.getElementById('mobile-menu');
        var pfEl = document.getElementById('pagefind-search');
        var fallback = document.getElementById('search-fallback');
        var initialized = false;

        function openSearch() {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          modal.setAttribute('aria-hidden', 'false');
          if (!initialized) {
            initialized = true;
            if (typeof window.PagefindUI !== 'undefined') {
              new window.PagefindUI({ element: '#pagefind-search', showSubResults: true, resetStyles: false });
            } else {
              pfEl.classList.add('hidden');
              fallback.classList.remove('hidden');
            }
          }
          setTimeout(function() {
            var inp = pfEl.querySelector('input');
            if (inp) inp.focus();
          }, 80);
        }

        function closeSearch() {
          modal.classList.add('hidden');
          document.body.style.overflow = '';
          modal.setAttribute('aria-hidden', 'true');
        }

        modal.setAttribute('aria-hidden', 'true');
        if (searchBtn) searchBtn.addEventListener('click', openSearch);
        if (mobileSearchBtn) mobileSearchBtn.addEventListener('click', function() {
          if (mobileMenu) mobileMenu.classList.add('hidden');
          openSearch();
        });
        if (backdrop) backdrop.addEventListener('click', closeSearch);
        if (closeBtn) closeBtn.addEventListener('click', closeSearch);

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closeSearch();
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
        });
      })();
    </script>

    <!-- Pagefind UI script — generated by build, silently absent in dev -->
    <script is:inline>
      (function() {
        var s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.onerror = function() {}; // silent in dev
        document.head.appendChild(s);
      })();
    </script>

    <!-- First-visit onboarding modal -->
    <OnboardingModal client:load />
  </body>
</html>
