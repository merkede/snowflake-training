---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Master Snowflake with comprehensive training for the SnowPro Core Certification (COF-C02)' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Social sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.png" />

    <!-- PWA / App -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#29b5e8" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Pagefind search UI (available after npm run build) -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body>
    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity no-underline">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-snowflake-blue), var(--color-snowflake-sky));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-lg text-slate-900">Snowflake Training</div>
              <div class="text-xs" style="color: var(--color-snowflake-blue);">by Hamzah Javaid</div>
            </div>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-1">
            <a href="/" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Home</a>
            <a href="/modules" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Modules</a>
            <a href="/flashcards" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Flashcards</a>
            <a href="/cheatsheets" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Cheat Sheets</a>
            <a href="/exam-sim" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">Mock Exam</a>
            <a href="/practice" class="px-3 py-2 text-slate-700 hover:text-primary font-medium transition-colors no-underline rounded-lg hover:bg-slate-50 text-sm">SQL Practice</a>
            <button
              id="search-button"
              class="ml-2 flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 text-slate-500 hover:border-primary hover:text-primary transition-all text-sm"
              aria-label="Search"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span class="hidden lg:inline">Search</span>
              <kbd class="hidden lg:inline text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-400 font-sans">⌘K</kbd>
            </button>
          </div>

          <!-- Mobile: search icon + hamburger -->
          <div class="flex md:hidden items-center gap-1">
            <button id="mobile-search-btn" class="p-2 rounded-lg text-slate-600 hover:bg-slate-100" aria-label="Search">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
            <button id="mobile-menu-btn" class="p-2 rounded-lg text-slate-600 hover:bg-slate-100" aria-label="Open menu">
              <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </nav>

      <!-- Mobile menu dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white shadow-lg">
        <nav class="max-w-7xl mx-auto px-4 py-3 space-y-1">
          <a href="/" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Home</a>
          <a href="/about" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">About</a>
          <a href="/modules" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Modules</a>
          <a href="/flashcards" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Flashcards</a>
          <a href="/cheatsheets" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Cheat Sheets</a>
          <a href="/exam-sim" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">Mock Exam</a>
          <a href="/practice" class="block px-4 py-3 rounded-lg text-slate-700 hover:bg-slate-50 font-medium no-underline text-sm">SQL Practice</a>
        </nav>
      </div>
    </header>

    <!-- Search Modal Overlay -->
    <div id="search-modal" class="hidden fixed inset-0 z-[200] flex items-start justify-center pt-16 px-4">
      <div id="search-backdrop" class="absolute inset-0" style="background: rgba(15,23,42,0.6); backdrop-filter: blur(4px);"></div>
      <div class="relative w-full max-w-2xl bg-white rounded-2xl shadow-2xl overflow-hidden" style="max-height: 80vh; display: flex; flex-direction: column;">
        <div class="p-4 overflow-y-auto flex-1">
          <div id="pagefind-search"></div>
          <div id="search-fallback" class="hidden py-10 text-center">
            <svg class="w-10 h-10 mx-auto mb-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p class="text-sm text-slate-500">Search is available in the production build.</p>
            <p class="text-xs text-slate-400 mt-1">Run <code class="bg-slate-100 px-1 py-0.5 rounded font-mono">npm run build</code> then <code class="bg-slate-100 px-1 py-0.5 rounded font-mono">npm run preview</code></p>
          </div>
        </div>
        <div class="px-4 py-3 border-t border-slate-100 bg-slate-50 flex items-center justify-between">
          <span class="text-xs text-slate-400">
            Press <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-xs">Esc</kbd> to close
            &nbsp;·&nbsp;
            <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-xs">⌘K</kbd> to open
          </span>
          <button id="close-search-btn" class="text-sm text-slate-500 hover:text-slate-800 font-medium">Close</button>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-300 mt-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid md:grid-cols-4 gap-8">
          <div class="md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-snowflake-blue), var(--color-snowflake-sky));">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
              </div>
              <div>
                <div class="font-bold text-white">Snowflake Training</div>
                <div class="text-xs" style="color: var(--color-snowflake-blue);">by Hamzah Javaid</div>
              </div>
            </div>
            <p class="text-sm text-slate-400 max-w-md">
              An internal Snowflake training resource for the Data Analytics and Data Science teams at Hastings Direct.
            </p>
          </div>

          <div>
            <h4 class="font-semibold text-white mb-4">Resources</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/modules" class="hover:text-primary transition-colors">All Modules</a></li>
              <li><a href="/flashcards" class="hover:text-primary transition-colors">Flashcards</a></li>
              <li><a href="/cheatsheets" class="hover:text-primary transition-colors">Cheat Sheets</a></li>
              <li><a href="/exam-sim" class="hover:text-primary transition-colors">Mock Exam</a></li>
              <li><a href="/practice" class="hover:text-primary transition-colors">SQL Practice</a></li>
              <li><a href="/about" class="hover:text-primary transition-colors">About</a></li>
            </ul>
          </div>

          <div>
            <h4 class="font-semibold text-white mb-4">Exam Domains</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/architecture" class="hover:text-primary transition-colors">Architecture</a></li>
              <li><a href="/security" class="hover:text-primary transition-colors">Security</a></li>
              <li><a href="/performance" class="hover:text-primary transition-colors">Performance</a></li>
              <li><a href="/data-loading" class="hover:text-primary transition-colors">Data Loading</a></li>
              <li><a href="/data-transformations" class="hover:text-primary transition-colors">Transformations</a></li>
              <li><a href="/data-protection" class="hover:text-primary transition-colors">Data Protection</a></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-slate-800 mt-8 pt-8 text-sm text-slate-400 text-center">
          <p>&copy; {new Date().getFullYear()} Hamzah Javaid.</p>
        </div>
      </div>
    </footer>

    <!-- Service Worker -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>

    <!-- Mobile menu -->
    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var menu = document.getElementById('mobile-menu');
        var ham = document.getElementById('hamburger-icon');
        var cls = document.getElementById('close-icon');
        if (!btn) return;
        btn.addEventListener('click', function() {
          var open = menu.classList.toggle('hidden');
          ham.classList.toggle('hidden', !open);
          cls.classList.toggle('hidden', open);
        });
      })();
    </script>

    <!-- Search modal + Pagefind -->
    <script is:inline>
      (function() {
        var modal = document.getElementById('search-modal');
        var backdrop = document.getElementById('search-backdrop');
        var closeBtn = document.getElementById('close-search-btn');
        var searchBtn = document.getElementById('search-button');
        var mobileSearchBtn = document.getElementById('mobile-search-btn');
        var mobileMenu = document.getElementById('mobile-menu');
        var pfEl = document.getElementById('pagefind-search');
        var fallback = document.getElementById('search-fallback');
        var initialized = false;

        function open() {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          if (!initialized) {
            initialized = true;
            if (typeof window.PagefindUI !== 'undefined') {
              new window.PagefindUI({ element: '#pagefind-search', showSubResults: true, resetStyles: false });
            } else {
              pfEl.classList.add('hidden');
              fallback.classList.remove('hidden');
            }
          }
          setTimeout(function() {
            var inp = pfEl.querySelector('input');
            if (inp) inp.focus();
          }, 80);
        }

        function close() {
          modal.classList.add('hidden');
          document.body.style.overflow = '';
        }

        if (searchBtn) searchBtn.addEventListener('click', open);
        if (mobileSearchBtn) mobileSearchBtn.addEventListener('click', function() {
          if (mobileMenu) mobileMenu.classList.add('hidden');
          open();
        });
        if (backdrop) backdrop.addEventListener('click', close);
        if (closeBtn) closeBtn.addEventListener('click', close);

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') close();
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); open(); }
        });
      })();
    </script>

    <!-- Pagefind UI script — generated by build, silently absent in dev -->
    <script is:inline>
      (function() {
        var s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.onerror = function() {}; // silent in dev
        document.head.appendChild(s);
      })();
    </script>
  </body>
</html>
