<script>
  // ── Scroll-reveal (IntersectionObserver) ─────────────────────────────────
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('[data-animate]').forEach((el) => io.observe(el));

  // ── Feature Showcase — phone fan + auto-rotate ───────────────────────────
  const featSection = document.getElementById('section-features') as HTMLElement | null;
  const fan = document.getElementById('feat-fan') as HTMLElement | null;

  if (fan && featSection) {
    const phones = Array.from(fan.querySelectorAll<HTMLElement>('[data-feat-phone]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-feat-panel]'));
    const dots   = Array.from(document.querySelectorAll<HTMLElement>('[data-feat-dot]'));
    const bgs    = ['rgba(240,249,255,0.5)', 'rgba(240,253,244,0.5)', 'rgba(250,245,255,0.5)'];

    // Fan slot definitions: [active/front, middle, back-peek]
    const SLOTS = [
      { x: 0,   y: 0,  scale: 1,    opacity: 1,    z: 3, shadow: '0 40px 80px rgba(0,0,0,0.28), 0 0 0 2px #1e293b' },
      { x: 105, y: 14, scale: 0.88, opacity: 0.68, z: 2, shadow: '0 24px 48px rgba(0,0,0,0.18), 0 0 0 2px #1e293b' },
      { x: 195, y: 26, scale: 0.78, opacity: 0.42, z: 1, shadow: '0 16px 32px rgba(0,0,0,0.12), 0 0 0 2px #1e293b' },
    ];

    let cur = 0;

    function goTo(idx: number) {
      cur = idx;
      // Update text panels
      panels.forEach((p, i) => p.classList.toggle('fs-active', i === idx));
      // Update dots
      dots.forEach((d, i) => d.classList.toggle('fs-active', i === idx));
      // Update phone fan positions
      phones.forEach((phone, i) => {
        const slot = (i - idx + phones.length) % phones.length;
        const s = SLOTS[slot];
        phone.style.transform = `translateX(${s.x}px) translateY(${s.y}px) scale(${s.scale})`;
        phone.style.opacity   = String(s.opacity);
        phone.style.zIndex    = String(s.z);
        phone.style.boxShadow = s.shadow;
      });
      // Background colour
      featSection.style.backgroundColor = bgs[idx];
    }

    // Initialise immediately
    goTo(0);

    // Auto-advance every 3.5 s
    let timer = window.setInterval(() => goTo((cur + 1) % 3), 3500);

    function manualGoTo(idx: number) {
      goTo(idx);
      clearInterval(timer);
      timer = window.setInterval(() => goTo((cur + 1) % 3), 3500);
    }

    dots.forEach((d, i) => d.addEventListener('click', () => manualGoTo(i)));

    // Clicking any non-active phone brings it to front
    phones.forEach((phone, i) => {
      phone.style.cursor = 'pointer';
      phone.addEventListener('click', () => {
        const slot = (i - cur + phones.length) % phones.length;
        if (slot !== 0) manualGoTo(i);
      });
    });
  }
</script>
