---
import Layout from '../layouts/Layout.astro';
import { flashcards } from '../data/flashcards';
import { examQuestions } from '../data/examQuestions';

const moduleCount = 23;
const flashcardCount = flashcards.length;
const examQCount = examQuestions.length;

const testimonials = [
  {
    quote: "I'd been putting off Snowflake certifications for two years. This finally made it feel achievable — and genuinely enjoyable to work through.",
    highlight: "genuinely enjoyable to work through",
    name: "Maya S.",
    role: "Data Analyst",
    tag: "Passed COF-C02 ✓",
  },
  {
    quote: "The mock exam is scarily accurate. Same format, same difficulty. I walked into the real exam feeling like I'd already done it.",
    highlight: "feeling like I'd already done it",
    name: "James T.",
    role: "Analytics Engineer",
    tag: "First attempt pass ✓",
  },
  {
    quote: "The flashcard algorithm knows when you're struggling before you do. I stopped second-guessing myself and just trusted the system.",
    highlight: "knows when you're struggling before you do",
    name: "Priya L.",
    role: "Data Engineer",
    tag: "Architecture & Security",
  },
  {
    quote: "Printed the cheat sheets on day one. Still have them on my desk three months later. The domain breakdowns are exactly what you need.",
    highlight: "Still have them on my desk",
    name: "Tom R.",
    role: "BI Developer",
    tag: "Data Loading & Unloading",
  },
  {
    quote: "The streak tracker is sneaky effective. I didn't want to break the chain — ended up studying every single day for six weeks straight.",
    highlight: "didn't want to break the chain",
    name: "Sarah K.",
    role: "Data Scientist",
    tag: "6-week study streak 🔥",
  },
  {
    quote: "Finally, Snowflake training that actually feels engaging. The inline quizzes make concepts stick in a way passive reading never does.",
    highlight: "actually feels engaging",
    name: "Dan O.",
    role: "Senior Data Analyst",
    tag: "Transformations domain",
  },
];

const domains = [
  { name: "Architecture & Features", pct: 25, href: "/architecture/overview",              icon: "🏗️", num: 1 },
  { name: "Account Access & Security", pct: 20, href: "/security/users-roles",             icon: "🔐", num: 2 },
  { name: "Performance Concepts",      pct: 15, href: "/performance/queries",              icon: "⚡", num: 3 },
  { name: "Data Loading & Unloading",  pct: 15, href: "/data-loading/bulk",               icon: "📥", num: 4 },
  { name: "Data Transformations",      pct: 15, href: "/data-transformations/sql-basics",  icon: "🔄", num: 5 },
  { name: "Data Protection & Sharing", pct: 10, href: "/data-protection/time-travel",     icon: "🛡️", num: 6 },
];
---

<Layout title="Snowflake Training | SnowPro Core COF-C02 | by Hamzah Javaid">

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden text-white"
    data-bg-theme
    data-bg1="12,28,52"
    data-bg2="18,54,84"
    data-bg3="10,88,112"
    data-accent="56,189,248"
    style="padding: 5rem 0 4rem;"
  >
    <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(135deg, rgba(15,23,42,0.66) 0%, rgba(30,46,74,0.5) 45%, rgba(15,23,42,0.68) 100%);"></div>

    <!-- Decorative snowflake rings -->
    <div aria-hidden="true" style="position: absolute; right: -120px; top: 50%; transform: translateY(-50%); pointer-events: none;">
      <div style="width: 500px; height: 500px; border: 1px solid rgba(41,181,232,0.08); border-radius: 50%;"></div>
      <div style="position: absolute; inset: 60px; border: 1px solid rgba(41,181,232,0.12); border-radius: 50%;"></div>
      <div style="position: absolute; inset: 120px; border: 1px solid rgba(41,181,232,0.16); border-radius: 50%;"></div>
      <div style="position: absolute; inset: 180px; font-size: 100px; display: flex; align-items: center; justify-content: center; color: rgba(41,181,232,0.06);">❄</div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-4xl mx-auto">

        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full mb-6" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.12);">
          <span class="text-sm font-medium text-slate-300">SnowPro Core (COF-C02) Exam Prep</span>
        </div>

        <!-- Progressive headline -->
        <div class="mb-6 flex flex-wrap justify-center gap-x-5 gap-y-1" style="font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.02em;">
          <span class="hero-word" style="color: white;">Study.</span>
          <span class="hero-word" style="color: rgba(255,255,255,0.3);">Practise.</span>
          <span class="hero-word" style="color: rgba(255,255,255,0.15);">Pass.</span>
        </div>

        <!-- Subtitle -->
        <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto" style="animation: heroWordReveal 0.65s ease 0.5s both;">
          The all-in-one SnowPro Core (COF-C02) prep resource —
          <span style="color: #29b5e8; font-weight: 600;">{moduleCount} modules, {flashcardCount} flashcards, {examQCount} exam questions.</span>
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16" style="animation: heroWordReveal 0.65s ease 0.65s both;">
          <a href="/modules" data-magnetic class="btn-primary text-lg px-8 py-4 no-underline">
            Start Learning →
          </a>
          <a href="/flashcards" data-magnetic class="text-lg px-8 py-4 no-underline font-semibold rounded-xl transition-all"
             style="background: rgba(255,255,255,0.08); color: white; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(8px);">
            Flashcards & Revision
          </a>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto" style="animation: heroWordReveal 0.65s ease 0.8s both;">
          {[
            { value: moduleCount, label: 'Modules' },
            { value: flashcardCount, label: 'Flashcards' },
            { value: examQCount, label: 'Exam Questions' },
            { value: 6, label: 'Exam Domains' },
          ].map(s => (
            <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem 1rem; text-align: center;">
              <div style="font-size: 2.25rem; font-weight: 900; color: #29b5e8; line-height: 1;">{s.value}</div>
              <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 0.25rem; font-weight: 500;">{s.label}</div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       FEATURE SHOWCASE — phone fan, auto-rotating
  ═══════════════════════════════════════════════════════════════ -->
  <section
    id="section-features"
    data-bg-theme
    data-bg1="6,78,110"
    data-bg2="18,104,130"
    data-bg3="7,89,125"
    data-accent="56,189,248"
    style="background: rgba(240, 249, 255, 0.5); transition: background-color 0.7s ease; padding: 5rem 0 4rem;"
  >

    <!-- DESKTOP: phone fan left, text right -->
    <div class="hidden lg:flex max-w-7xl mx-auto px-8 items-center gap-16" style="min-height: 520px;">

      <!-- Text panels (right) -->
      <div style="flex: 1; position: relative; height: 400px; order: 2;">

        <!-- Panel 0: Modules -->
        <div class="feature-text-panel fs-active" data-feat-panel="0">
          <span style="display:inline-block;padding:0.25rem 0.875rem;border-radius:9999px;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;background:#e0f2fe;color:#0369a1;margin-bottom:1.25rem;width:fit-content;">23 Modules</span>
          <h3 style="font-size:2.125rem;font-weight:800;color:#0f172a;letter-spacing:-0.02em;line-height:1.15;margin:0 0 1rem;">Read through every<br/>exam domain.</h3>
          <p style="color:#64748b;font-size:1.0625rem;line-height:1.7;margin:0 0 1.5rem;">Structured content covering all 6 COF-C02 domains — with diagrams, code examples, and inline practice questions. Modules auto-complete as you scroll to the end.</p>
          <ul style="list-style:none;padding:0;margin:0 0 2rem;display:flex;flex-direction:column;gap:0.5rem;">
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Auto-marks complete when you finish reading</li>
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Progress saved across sessions</li>
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Estimated read time per module</li>
          </ul>
          <a href="/modules" class="btn-primary inline-block no-underline">Explore Modules &#8594;</a>
        </div>

        <!-- Panel 1: Flashcards -->
        <div class="feature-text-panel" data-feat-panel="1">
          <span style="display:inline-block;padding:0.25rem 0.875rem;border-radius:9999px;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;background:#d1fae5;color:#065f46;margin-bottom:1.25rem;width:fit-content;">SM-2 Spaced Repetition</span>
          <h3 style="font-size:2.125rem;font-weight:800;color:#0f172a;letter-spacing:-0.02em;line-height:1.15;margin:0 0 1rem;">Drill with flashcards<br/>that actually work.</h3>
          <p style="color:#64748b;font-size:1.0625rem;line-height:1.7;margin:0 0 1.5rem;">The SM-2 algorithm schedules cards based on how well you know them — spacing out easy cards and surfacing difficult ones more often.</p>
          <ul style="list-style:none;padding:0;margin:0 0 2rem;display:flex;flex-direction:column;gap:0.5rem;">
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>{flashcardCount}+ exam-focused flashcards</li>
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Filter by domain — focus where you're weakest</li>
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Daily streak tracker for consistency</li>
          </ul>
          <a href="/flashcards" class="btn-primary inline-block no-underline">Start Flashcards &#8594;</a>
        </div>

        <!-- Panel 2: Mock Exam -->
        <div class="feature-text-panel" data-feat-panel="2">
          <span style="display:inline-block;padding:0.25rem 0.875rem;border-radius:9999px;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;background:#ede9fe;color:#5b21b6;margin-bottom:1.25rem;width:fit-content;">Mock Exam</span>
          <h3 style="font-size:2.125rem;font-weight:800;color:#0f172a;letter-spacing:-0.02em;line-height:1.15;margin:0 0 1rem;">Sit the full exam<br/>before the real one.</h3>
          <p style="color:#64748b;font-size:1.0625rem;line-height:1.7;margin:0 0 1.5rem;">{examQCount} timed questions in the exact COF-C02 format. Full explanations for every answer, history saved across attempts.</p>
          <ul style="list-style:none;padding:0;margin:0 0 2rem;display:flex;flex-direction:column;gap:0.5rem;">
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>{examQCount} questions across all 6 domains</li>
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Same 115-minute time limit as the real exam</li>
            <li style="display:flex;align-items:center;gap:0.625rem;font-size:0.875rem;color:#475569;"><span style="width:17px;height:17px;background:#dcfce7;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;color:#16a34a;font-weight:700;">&#10003;</span>Domain-by-domain score breakdown</li>
          </ul>
          <a href="/exam-sim" class="btn-primary inline-block no-underline">Take the Mock Exam &#8594;</a>
        </div>

        <!-- Progress dots (sit at bottom of text area) -->
        <div style="position:absolute;bottom:0;left:0;display:flex;gap:0.5rem;align-items:center;">
          <button class="feature-dot fs-active" data-feat-dot="0" aria-label="View Modules"></button>
          <button class="feature-dot" data-feat-dot="1" aria-label="View Flashcards"></button>
          <button class="feature-dot" data-feat-dot="2" aria-label="View Mock Exam"></button>
        </div>

      </div>

      <!-- Phone fan (left) -->
      <div id="feat-fan" style="position:relative;width:430px;height:510px;flex-shrink:0;order:1;">

        <!-- Phone 0: Modules -->
        <div class="feat-phone" data-feat-phone="0">
          <div class="feat-phone-notch"></div>
          <div class="feat-phone-inner" style="background:#f8fafc;">
            <div style="height:26px;background:#0f172a;display:flex;align-items:center;padding:0 14px;justify-content:space-between;flex-shrink:0;">
              <span style="color:#64748b;font-size:8px;font-weight:600;">9:41</span>
              <span style="color:#64748b;font-size:8px;">&#9679;&#9679;&#9679;</span>
            </div>
            <div style="background:linear-gradient(135deg,#0f172a,#1e3a5f);padding:12px 14px;flex-shrink:0;">
              <div style="font-size:8px;color:#29b5e8;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:3px;">COF-C02 PREP</div>
              <div style="font-size:15px;font-weight:800;color:white;margin-bottom:8px;">Your Progress</div>
              <div style="background:rgba(255,255,255,0.08);border-radius:8px;padding:6px 10px;display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:22px;font-weight:900;color:#29b5e8;line-height:1;">52%</span>
                <span style="font-size:9px;color:#94a3b8;">12 of 23 modules</span>
              </div>
              <div style="background:rgba(255,255,255,0.1);border-radius:4px;height:3px;margin-top:6px;overflow:hidden;">
                <div style="width:52%;height:100%;background:linear-gradient(90deg,#29b5e8,#56c4ed);border-radius:4px;"></div>
              </div>
            </div>
            <div style="flex:1;padding:8px 6px;overflow:hidden;display:flex;flex-direction:column;gap:3px;">
              <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;background:white;border-radius:7px;border:1px solid #e2e8f0;"><div style="width:15px;height:15px;border-radius:50%;background:#16a34a;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="color:white;font-size:8px;font-weight:700;">&#10003;</span></div><span style="font-size:9px;color:#94a3b8;text-decoration:line-through;">Introduction to Snowflake</span></div>
              <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;background:white;border-radius:7px;border:1px solid #e2e8f0;"><div style="width:15px;height:15px;border-radius:50%;background:#16a34a;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="color:white;font-size:8px;font-weight:700;">&#10003;</span></div><span style="font-size:9px;color:#94a3b8;text-decoration:line-through;">Snowflake Architecture</span></div>
              <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;background:#f0f9ff;border-radius:7px;border:2px solid #29b5e8;"><div style="width:15px;height:15px;border-radius:50%;background:#29b5e8;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><span style="color:white;font-size:8px;font-weight:700;">&#8594;</span></div><span style="font-size:9px;color:#0c4a6e;font-weight:600;">Databases &amp; Schemas</span></div>
              <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;background:white;border-radius:7px;border:1px solid #e2e8f0;"><div style="width:15px;height:15px;border-radius:50%;background:#e2e8f0;flex-shrink:0;"></div><span style="font-size:9px;color:#64748b;">Virtual Warehouses</span></div>
              <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;background:white;border-radius:7px;border:1px solid #e2e8f0;"><div style="width:15px;height:15px;border-radius:50%;background:#e2e8f0;flex-shrink:0;"></div><span style="font-size:9px;color:#64748b;">Data Storage &amp; Clustering</span></div>
              <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;background:white;border-radius:7px;border:1px solid #e2e8f0;"><div style="width:15px;height:15px;border-radius:50%;background:#e2e8f0;flex-shrink:0;"></div><span style="font-size:9px;color:#64748b;">User &amp; Role Management</span></div>
            </div>
          </div>
        </div>

        <!-- Phone 1: Flashcards -->
        <div class="feat-phone" data-feat-phone="1">
          <div class="feat-phone-notch"></div>
          <div class="feat-phone-inner" style="background:#f1f5f9;">
            <div style="height:26px;background:#1e293b;display:flex;align-items:center;padding:0 14px;justify-content:space-between;flex-shrink:0;">
              <span style="color:#64748b;font-size:8px;font-weight:600;">9:41</span>
              <span style="color:#64748b;font-size:8px;">&#9679;&#9679;&#9679;</span>
            </div>
            <div style="background:white;padding:8px 8px 0;border-bottom:1px solid #e2e8f0;flex-shrink:0;">
              <div style="display:flex;gap:3px;">
                <div style="padding:4px 8px;background:#29b5e8;color:white;border-radius:5px 5px 0 0;font-size:8px;font-weight:700;white-space:nowrap;">Architecture</div>
                <div style="padding:4px 8px;color:#94a3b8;font-size:8px;white-space:nowrap;">Security</div>
                <div style="padding:4px 8px;color:#94a3b8;font-size:8px;white-space:nowrap;">Performance</div>
              </div>
            </div>
            <div style="text-align:center;padding:8px 0 4px;font-size:9px;color:#94a3b8;font-weight:600;letter-spacing:1px;flex-shrink:0;">CARD 5 OF 24</div>
            <div style="flex:1;padding:0 10px 10px;display:flex;flex-direction:column;">
              <div style="background:white;border-radius:14px;padding:16px 14px;box-shadow:0 4px 24px rgba(0,0,0,0.08);flex:1;display:flex;flex-direction:column;justify-content:center;border:1px solid #e2e8f0;">
                <div style="font-size:8px;color:#29b5e8;font-weight:700;letter-spacing:1px;text-transform:uppercase;text-align:center;margin-bottom:8px;">ARCHITECTURE</div>
                <div style="font-size:11px;font-weight:600;color:#1e293b;line-height:1.5;text-align:center;">What are the three layers of Snowflake's multi-cluster shared data architecture?</div>
                <div style="margin-top:12px;padding:7px 10px;background:#f8fafc;border-radius:7px;border:1px dashed #cbd5e1;text-align:center;">
                  <div style="font-size:8px;color:#94a3b8;font-weight:500;">Tap to reveal answer</div>
                </div>
              </div>
              <div style="display:flex;gap:5px;margin-top:8px;">
                <button style="flex:1;padding:6px 0;background:#fef2f2;border:1px solid #fecaca;border-radius:7px;font-size:8px;font-weight:700;color:#dc2626;">Hard</button>
                <button style="flex:1;padding:6px 0;background:#fffbeb;border:1px solid #fed7aa;border-radius:7px;font-size:8px;font-weight:700;color:#d97706;">OK</button>
                <button style="flex:1;padding:6px 0;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:7px;font-size:8px;font-weight:700;color:#16a34a;">Easy</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone 2: Mock Exam -->
        <div class="feat-phone" data-feat-phone="2">
          <div class="feat-phone-notch"></div>
          <div class="feat-phone-inner" style="background:#f8fafc;">
            <div style="height:26px;background:#1e293b;display:flex;align-items:center;padding:0 14px;justify-content:space-between;flex-shrink:0;">
              <span style="color:#64748b;font-size:8px;font-weight:600;">9:41</span>
              <span style="color:#29b5e8;font-size:8px;font-weight:700;">47:23</span>
            </div>
            <div style="background:white;padding:8px 12px;border-bottom:1px solid #e2e8f0;flex-shrink:0;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;">
                <span style="font-size:9px;font-weight:700;color:#1e293b;">Q12 / {examQCount}</span>
                <span style="background:#fef3c7;color:#92400e;font-size:8px;font-weight:700;padding:2px 7px;border-radius:9px;">47:23</span>
              </div>
              <div style="background:#e2e8f0;border-radius:3px;height:3px;overflow:hidden;">
                <div style="width:12%;height:100%;background:linear-gradient(90deg,#29b5e8,#56c4ed);"></div>
              </div>
            </div>
            <div style="flex:1;padding:10px 12px;overflow:hidden;display:flex;flex-direction:column;">
              <div style="font-size:8px;color:#29b5e8;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;">DATA PROTECTION</div>
              <div style="font-size:10px;font-weight:600;color:#1e293b;line-height:1.55;margin-bottom:10px;">Which Snowflake feature allows data sharing between accounts without copying data?</div>
