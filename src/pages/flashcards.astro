---
import Layout from '../layouts/Layout.astro';
import FlashcardsApp from '../components/FlashcardsApp';
import { flashcards } from '../data/flashcards';

const totalCards = flashcards.length;
const domains = [...new Set(flashcards.map(f => f.domain))].length;
---

<Layout
  title="Flashcards — Snowflake Training"
  description="Spaced repetition flashcards for the SnowPro Core COF-C02 exam. The SM-2 algorithm shows you cards when you need them most."
>
  <!-- Hero -->
  <div class="bg-gradient-to-b from-slate-50 to-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">🃏</span>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color: var(--color-snowflake-blue);">Spaced Repetition</p>
          <h1 class="mb-0">Flashcards</h1>
        </div>
      </div>
      <p class="text-xl text-slate-600 max-w-3xl">
        {totalCards} cards across {domains} domains. The SM-2 spaced repetition algorithm shows you each card at the optimal time — more often when you struggle, less when you've mastered it.
      </p>

      <!-- How it works -->
      <div class="flex flex-wrap gap-4 mt-6">
        {[
          { rating: 'Again', color: '#ef4444', desc: 'Forgot — review tomorrow' },
          { rating: 'Hard', color: '#f97316', desc: 'Struggled — review in a few days' },
          { rating: 'Good', color: '#22c55e', desc: 'Remembered — interval grows' },
          { rating: 'Easy', color: '#29b5e8', desc: 'Nailed it — longer interval' },
        ].map(r => (
          <div class="flex items-center gap-2 text-sm">
            <span class="w-3 h-3 rounded-full flex-shrink-0" style={`background: ${r.color};`}></span>
            <span class="font-semibold" style={`color: ${r.color};`}>{r.rating}</span>
            <span class="text-slate-500">{r.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- App -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <FlashcardsApp client:load />

    <!-- Bottom CTA -->
    <div class="card text-center mt-16" style="background: linear-gradient(135deg, var(--color-snowflake-light) 0%, white 100%);">
      <h3 class="text-2xl font-bold mb-4">Ready for the Real Thing?</h3>
      <p class="text-slate-600 mb-6">
        Test yourself with a full 100-question timed mock exam that mirrors the COF-C02 format.
      </p>
      <a href="/exam-sim" class="btn-primary inline-block no-underline">
        Take the Mock Exam
      </a>
    </div>
  </div>
</Layout>
