---
import Layout from '../layouts/Layout.astro';
import ExamSimulator from '../components/ExamSimulator';
---

<Layout
  title="Mock Exam — COF-C02 Simulator | Snowflake Training"
  description="Full 100-question timed mock exam and quick practice mode for the Snowflake SnowPro Core (COF-C02) certification."
>
  <!-- Hero -->
  <div class="bg-gradient-to-b from-slate-50 to-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">📋</span>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color: var(--color-snowflake-blue);">COF-C02 Exam Prep</p>
          <h1 class="mb-0">Mock Exam Simulator</h1>
        </div>
      </div>
      <p class="text-xl text-slate-600 max-w-3xl">
        100 exam-style questions across all six COF-C02 domains. Full timed mode (115 min) or quick domain practice. Pass mark is 75%.
      </p>

      <!-- Feature pills -->
      <div class="flex flex-wrap gap-2 mt-6">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
          100 questions
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-purple-50 text-purple-700">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          115-minute timer
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          Domain score breakdown
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" /></svg>
          Flag & review questions
        </span>
      </div>
    </div>
  </div>

  <!-- Simulator -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <ExamSimulator client:load />
  </div>
</Layout>
